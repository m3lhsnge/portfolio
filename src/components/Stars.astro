<!-- Twinkling Stars Canvas Background -->
<canvas id="starfield"></canvas>

<style>
	#starfield {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}
</style>

<script>
	const canvas = document.getElementById('starfield') as HTMLCanvasElement;
	const ctx = canvas.getContext('2d')!;

	interface Star {
		x: number;
		y: number;
		radius: number;
		opacity: number;
		speed: number;
		direction: number; // 1 = brightening, -1 = dimming
		color: string;
	}

	const STAR_COUNT_DESKTOP = 220;
	const STAR_COUNT_MOBILE = 120;
	let stars: Star[] = [];

	const starColors = [
		'255, 255, 255',   // white
		'200, 220, 255',   // cool blue-white
		'255, 240, 220',   // warm white
		'180, 200, 255',   // light blue
		'255, 210, 180',   // pale orange
		'220, 200, 255',   // lavender
	];

	function getStarCount(): number {
		return window.innerWidth < 768 ? STAR_COUNT_MOBILE : STAR_COUNT_DESKTOP;
	}

	function createStar(): Star {
		return {
			x: Math.random() * canvas.width,
			y: Math.random() * canvas.height,
			radius: Math.random() * 1.8 + 0.3,
			opacity: Math.random(),
			speed: Math.random() * 0.008 + 0.002,
			direction: Math.random() > 0.5 ? 1 : -1,
			color: starColors[Math.floor(Math.random() * starColors.length)],
		};
	}

	function initStars(): void {
		canvas.width = window.innerWidth;
		canvas.height = window.innerHeight;
		const count = getStarCount();
		stars = Array.from({ length: count }, () => createStar());
	}

	function drawStar(star: Star): void {
		// Glow effect
		const gradient = ctx.createRadialGradient(
			star.x, star.y, 0,
			star.x, star.y, star.radius * 3
		);
		gradient.addColorStop(0, `rgba(${star.color}, ${star.opacity})`);
		gradient.addColorStop(0.4, `rgba(${star.color}, ${star.opacity * 0.3})`);
		gradient.addColorStop(1, `rgba(${star.color}, 0)`);

		ctx.beginPath();
		ctx.arc(star.x, star.y, star.radius * 3, 0, Math.PI * 2);
		ctx.fillStyle = gradient;
		ctx.fill();

		// Core
		ctx.beginPath();
		ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
		ctx.fillStyle = `rgba(${star.color}, ${star.opacity})`;
		ctx.fill();
	}

	function animate(): void {
		ctx.clearRect(0, 0, canvas.width, canvas.height);

		for (const star of stars) {
			star.opacity += star.speed * star.direction;

			if (star.opacity >= 1) {
				star.opacity = 1;
				star.direction = -1;
			} else if (star.opacity <= 0.05) {
				star.opacity = 0.05;
				star.direction = 1;
			}

			drawStar(star);
		}

		requestAnimationFrame(animate);
	}

	// Occasional shooting star
	function shootingStar(): void {
		const x = Math.random() * canvas.width;
		const y = Math.random() * canvas.height * 0.5;
		const length = Math.random() * 120 + 60;
		const angle = Math.PI / 4 + (Math.random() * 0.3 - 0.15);
		const speed = 8;
		let progress = 0;

		function drawShootingStar(): void {
			if (progress > length + 40) return;

			const currentX = x + Math.cos(angle) * progress;
			const currentY = y + Math.sin(angle) * progress;
			const tailX = x + Math.cos(angle) * Math.max(0, progress - 40);
			const tailY = y + Math.sin(angle) * Math.max(0, progress - 40);

			const gradient = ctx.createLinearGradient(tailX, tailY, currentX, currentY);
			gradient.addColorStop(0, 'rgba(255, 255, 255, 0)');
			gradient.addColorStop(1, `rgba(255, 255, 255, ${1 - progress / (length + 40)})`);

			ctx.beginPath();
			ctx.moveTo(tailX, tailY);
			ctx.lineTo(currentX, currentY);
			ctx.strokeStyle = gradient;
			ctx.lineWidth = 1.5;
			ctx.stroke();

			progress += speed;
			requestAnimationFrame(drawShootingStar);
		}

		drawShootingStar();
	}

	// Random shooting stars
	function scheduleShootingStar(): void {
		const delay = Math.random() * 6000 + 3000;
		setTimeout(() => {
			shootingStar();
			scheduleShootingStar();
		}, delay);
	}

	// Init
	initStars();
	animate();
	scheduleShootingStar();

	// Resize handler
	let resizeTimeout: number;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimeout);
		resizeTimeout = window.setTimeout(() => {
			initStars();
		}, 150);
	});
</script>
