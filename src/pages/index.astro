---
import Layout from '../layouts/Layout.astro';
import Stars from '../components/Stars.astro';
---

<Layout>
	<Stars />

	<div class="page-wrapper">
		<!-- Top-left logo -->
		<header>
			<a href="/" class="logo" id="logo-link">melhakaa</a>
		</header>

		<!-- Hero Section -->
		<main>
			<div class="hero">
				<h1 class="hero-name">
					<span class="name-first">Melih</span>
					<span class="name-last">Aka</span>
				</h1>
				<p class="hero-title">Yazılım Mühendisi</p>
				<div class="hero-divider"></div>

				<!-- CV Download -->
				<a href={`${import.meta.env.BASE_URL}cv.pdf`} target="_blank" rel="noopener noreferrer" class="cv-btn" id="cv-download">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
